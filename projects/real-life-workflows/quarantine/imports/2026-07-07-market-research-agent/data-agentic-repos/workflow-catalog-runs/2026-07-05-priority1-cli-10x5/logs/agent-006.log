ry folder listing closing-coordinator.md and funds-flow-manager.md.","validation_gate":"Confirm required closing artifacts exist, source files are linked, payment-sensitive items are flagged for human review, and exceptions are separated from confirmed facts.","human_review_boundary":"Required before any payment, signature, wire, escrow, legal, or third-party closing action; optional only for internal reference cataloging.","safety_boundary":"Reference pattern only until copied into an ECC contract; do not initiate payments, sign documents, approve wires, or give legal conclusions.","codex_package_relevance":"Useful as a checklist and exception-tracking pattern for due-diligence packets where evidence completeness matters.","what_to_copy":"Copy closing-readiness checklist structure, exception tracking, evidence status labels, and human escalation boundary.","what_to_ignore":"Ignore transaction execution, funds movement, signature routing, or external communications without explicit approval.","tags":"closing, real_estate, due_diligence, evidence_audit, funds_flow, checklist","confidence":"medium"},{"workflow_id":"surface-0047","workflow_name":"Document Ingestion","source_repo":"ahacker-1/cre-agent-skills","source_url":"https://github.com/ahacker-1/cre-agent-skills/tree/main/skills/document-ingestion","source_url_status":"exact_page_reachable","canonical_source_url":"https://github.com/ahacker-1/cre-agent-skills/tree/main/skills/document-ingestion","evidence_basis":"category folder","domain":"real_estate","workflow_type":"DocumentIngestion reference package for real estate evidence extraction","real_life_job":"Classify and parse commercial real estate diligence documents such as financials, offering memoranda, rent rolls, and related evidence files.","input_contract":"Uploaded or linked documents, document metadata, property/entity identifiers, OCR text where available, financial statements, offering memoranda, rent rolls, and source file references.","output_artifact":"Classified document inventory, extracted data table, parser notes, source-linked evidence packet, or caveated ingestion report.","trigger":"Use when the catalog lookup needs a document intake and extraction pattern for due-diligence evidence.","tools_or_sources":"GitHub category folder listing document-classifier.md, financials-parser.md, offering-memo-parser.md, and rent-roll-parser.md.","validation_gate":"Check file provenance, document classification confidence, parse completeness, field-level source traceability, and unresolved OCR or extraction caveats.","human_review_boundary":"Human review required before using extracted financial, lease, title, legal, safety, or compliance data for decisions; optional for catalog-only reference.","safety_boundary":"Reference pattern only until copied into an ECC contract; do not treat extracted fields as authoritative without source review.","codex_package_relevance":"Strongly relevant as a reusable ingestion pattern for evidence packets and public-source audit workflows.","what_to_copy":"Copy document inventory, source-file preservation, field extraction with confidence/caveats, and parse validation gates.","what_to_ignore":"Ignore assumptions that all source documents are private transaction files; adapt only the ingestion pattern to public evidence workflows.","tags":"document_ingestion, real_estate, due_diligence, evidence_audit, extraction, parser","confidence":"medium"},{"workflow_id":"surface-0048","workflow_name":"Due Diligence","source_repo":"ahacker-1/cre-agent-skills","source_url":"https://github.com/ahacker-1/cre-agent-skills/tree/main/skills/due-diligence","source_url_status":"exact_page_reachable","canonical_source_url":"https://github.com/ahacker-1/cre-agent-skills/tree/main/skills/due-diligence","evidence_basis":"category folder","domain":"real_estate","workflow_type":"EvidenceAudit reference package for real estate diligence review","real_life_job":"Review commercial real estate environmental, legal/title, market, operating expense, physical inspection, rent roll, and tenant credit evidence before a transaction or asset decision.","input_contract":"Environmental reports, title/legal records, market data, operating statements, physical inspection materials, rent roll, tenant credit data, property identifiers, entity names, and cited source files or URLs.","output_artifact":"Due-diligence packet, issue log, source-attributed evidence brief, risk register, or caveated reviewer report.","trigger":"Use when the catalog lookup needs a broad real estate due-diligence evidence-audit pattern.","tools_or_sources":"GitHub category folder listing environmental-review.md, legal-title-review.md, market-study.md, opex-analyst.md, physical-inspection.md, rent-roll-analyst.md, and tenant-credit.md.","validation_gate":"Require source reachability, field-level citation, separation of facts from interpretations, freshness checks, unresolved exception list, and mandatory human review for final conclusions.","human_review_boundary":"Required before final action or conclusion, especially for legal/title, environmental, physical safety, credit, compliance, or investment use.","safety_boundary":"Must not make legal, medical, engineering, compliance, safety, credit, or investment conclusions without qualified human review.","codex_package_relevance":"Closest fit for evidence-packet structure and review gates; useful pattern material for ECC due-diligence workflows with explicit caveats.","what_to_copy":"Copy multi-lane evidence review, issue logs, source attribution, exception handling, and mandatory review boundary.","what_to_ignore":"Ignore domain-specific conclusions and any implied authority to certify legal, environmental, engineering, tenant-credit, or safety status.","tags":"due_diligence, real_estate, evidence_audit, title, environmental, physical_inspection, rent_roll","confidence":"medium_high"},{"workflow_id":"surface-0049","workflow_name":"Financing","source_repo":"ahacker-1/cre-agent-skills","source_url":"https://github.com/ahacker-1/cre-agent-skills/tree/main/skills/financing","source_url_status":"exact_page_reachable","canonical_source_url":"https://github.com/ahacker-1/cre-agent-skills/tree/main/skills/financing","evidence_basis":"category folder","domain":"real_estate","workflow_type":"EvidenceAudit reference package for real estate financing materials","real_life_job":"Prepare, compare, and review lender outreach materials, financing quotes, and term sheets for a commercial real estate transaction.","input_contract":"Lender list, outreach draft, financing quotes, term sheets, borrower/property identifiers, loan assumptions, supporting financial documents, and source links or files.","output_artifact":"Financing comparison packet, quote-comparison table, term-sheet draft or review brief, lender outreach package, and caveated financing memo.","trigger":"Use when the catalog lookup needs a real estate financing evidence and comparison reference pattern.","tools_or_sources":"GitHub category folder listing lender-outreach.md, quote-comparator.md, and term-sheet-builder.md.","validation_gate":"Trace each financing term to its source, flag missing assumptions, compare quote fields consistently, and preserve caveats before any external use.","human_review_boundary":"Human review required before lender contact, offer acceptance, borrower communication, investment decision, or external reliance; optional only for internal reference cataloging.","safety_boundary":"Reference pattern only until copied into an ECC contract; do not send outreach, negotiate terms, or provide financial/legal advice without approval and review.","codex_package_relevance":"Useful for structured comparison and evidence traceability patterns, with limited direct relevance to public building-code evidence workflows.","what_to_copy":"Copy term comparison tables, assumption tracking, source-linked financing evidence, and review-before-external-action gates.","what_to_ignore":"Ignore outreach execution, negotiation automation, and any claim that financing terms are advice or final recommendations.","tags":"financing, real_estate, due_diligence, evidence_audit, term_sheet, quote_comparison","confidence":"medium"}]}
