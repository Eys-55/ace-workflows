data/agentic-repos/workflow-catalog-runs/2026-07-05-priority1-cli-10x5/outputs/agent-005.md:1:{"agent_id":"codex","quality_note":"Read-only classification of 5 requested doors. Classifications preserve input workflow_id values and are limited to source-visible folders, files, README fallback evidence, or sparse-source caveats.","rows":[{"workflow_id":"surface-0125","workflow_name":"Moodle","source_repo":"ritik-prog/n8n-automation-templates-5000","source_url":"https://github.com/ritik-prog/n8n-automation-templates-5000/tree/main/Templates based on paltforms/Moodle","source_url_status":"exact_page_reachable","canonical_source_url":"https://github.com/ritik-prog/n8n-automation-templates-5000/tree/main/Templates based on paltforms/Moodle","evidence_basis":"category folder","domain":"education","workflow_type":"EducationSupport","real_life_job":"Find Moodle-oriented automation examples for scheduled, polling, webhook, and integration workflows around education systems.","input_contract":"student/course/admin context, Moodle records or events, education materials, assessment or support data","output_artifact":"lesson/support plan, assessment artifact, admin packet, or automation pattern note","trigger":"Use when catalog lookup needs Moodle or education-platform automation inspiration.","tools_or_sources":"Moodle folder lists education-labeled JSON templates including scheduled, polling, webhook, Moodle-to-Notion, Moodle-to-Google-Sheets, and OpenAI-to-Moodle examples.","validation_gate":"Confirm the specific JSON template contents before copying behavior; folder listing alone only proves template names and platform category.","human_review_boundary":"recommended before sending/publishing/writing externally","safety_boundary":"do not treat runtime platform as Codex architecture unless explicitly chosen","codex_package_relevance":"Runtime/platform inspiration only; useful for education workflow ideas, not as an ECC/Codex architecture source.","what_to_copy":"Copy the source taxonomy idea: Moodle as an education workflow door with trigger/integration examples.","what_to_ignore":"Ignore n8n runtime assumptions and any uninspected template internals until a specific JSON file is opened.","tags":"education, Moodle, n8n, automation templates, platform inspiration, sparse internals","confidence":"medium"},{"workflow_id":"surface-0038","workflow_name":"Security Operations & GRC Workflows","source_repo":"agentskillexchange/skills","source_url":"https://github.com/agentskillexchange/skills/blob/main/industries/security-operations-grc-workflows.md","source_url_status":"exact_page_reachable","canonical_source_url":"https://github.com/agentskillexchange/skills/blob/main/industries/security-operations-grc-workflows.md","evidence_basis":"exact page","domain":"public_evidence","workflow_type":"EvidenceAudit","real_life_job":"Produce audit-ready security, governance, release-risk, policy-evidence, and investigation workflow packets from inspectable technical records.","input_contract":"public records, source links, addresses, entity names, evidence files, repository surfaces, logs, SBOMs, policy artifacts, dependency or configuration evidence","output_artifact":"evidence packet, due-diligence brief, caveated report, approval gate packet, SOC timeline, compliance artifact bundle","trigger":"Use when catalog lookup needs evidence-gated security operations, governance, approval, or compliance workflow patterns.","tools_or_sources":"The page names workflows for dependency and image scanning, secret and unsafe configuration discovery, risky action approval gates, SBOM/signature/vulnerability/event-log/policy artifacts, and SOC investigation packets.","validation_gate":"Require source URL, artifact presence, freshness, and human approval status checks before final conclusions or actions.","human_review_boundary":"required before final action or conclusion","safety_boundary":"must not make legal, medical, engineering, compliance, or safety conclusions without human review","codex_package_relevance":"Strong reference for evidence-gated workflow shape: collect, scan, route risk through approval, preserve policy evidence, and hand off remediation.","what_to_copy":"Copy the audit packet pattern, approval-gate framing, artifact checklist, and evidence-first language.","what_to_ignore":"Do not copy vendor-specific picks or operational claims without independently checking the underlying tools and context.","tags":"security operations, GRC, evidence audit, approval gates, compliance evidence, SOC, policy evidence","confidence":"high"},{"workflow_id":"surface-0042","workflow_name":"Asset Management","source_repo":"ahacker-1/cre-agent-skills","source_url":"https://github.com/ahacker-1/cre-agent-skills/tree/main/skills/asset-management","source_url_status":"exact_page_reachable","canonical_source_url":"https://github.com/ahacker-1/cre-agent-skills/tree/main/skills/asset-management","evidence_basis":"category folder","domain":"real_estate","workflow_type":"EvidenceAudit","real_life_job":"Support post-acquisition commercial real estate asset-management analysis across budgeting, variance, collections, renewals, lease-up, capex, NOI, hold/sell/refi, and quarterly review workflows.","input_contract":"property operating data, rent rolls, T-12 or budget files, variance records, renewal context, capex plans, ownership or investor reporting context","output_artifact":"evidence packet, due-diligence brief, caveated report, budget/variance review, capex tracker, NOI lever list, quarterly asset review memo","trigger":"Use when catalog lookup needs commercial real estate post-closing operations or asset-management workflow references.","tools_or_sources":"Exact folder lists nine asset-management skill files: annual operating budget, capex tracker, hold/sell/refi analyst, lease-up concessions, monthly variance, NOI improvement, quarterly review, renewal decision, and rent collection delinquency manager.","validation_gate":"Verify the specific skill file before adopting detailed behavior; folder evidence supports category and job coverage, not full internal workflow guarantees.","human_review_boundary":"optional unless output affects a person or external system","safety_boundary":"keep as reference pattern until copied into an ECC contract","codex_package_relevance":"Useful as a CRE workflow catalog reference for operational analysis doors and output artifact names.","what_to_copy":"Copy the folder-level taxonomy and repeated-job labels for CRE asset operations.","what_to_ignore":"Ignore unverified financial recommendations, benchmark assumptions, and any platform-specific install behavior until individual files are inspected.","tags":"commercial real estate, asset management, operations, budgeting, variance, capex, NOI, evidence audit","confidence":"medium"},{"workflow_id":"surface-0043","workflow_name":"Brokerage","source_repo":"ahacker-1/cre-agent-skills","source_url":"https://github.com/ahacker-1/cre-agent-skills/tree/main/skills/brokerage","source_url_status":"exact_page_reachable","canonical_source_url":"https://github.com/ahacker-1/cre-agent-skills/tree/main/skills/brokerage","evidence_basis":"category folder","domain":"real_estate","workflow_type":"EvidenceAudit","real_life_job":"Support commercial real estate seller-side brokerage workflows from assignment intake and broker opinion of value through marketing, buyer process, bid leveling, negotiation brief, and PSA-to-close coordination.","input_contract":"property records, seller assignment context, market/comparable evidence, data-room materials, bid terms, buyer process notes, transaction documents","output_artifact":"evidence packet, due-diligence brief, caveated report, broker opinion of value, listing proposal, offering memorandum or teaser, bid-leveling summary, negotiation brief","trigger":"Use when catalog lookup needs commercial real estate brokerage or investment-sales workflow references.","tools_or_sources":"Exact folder lists brokerage skill files for assignment intake, broker opinion of value, buyer process and data room, call for offers and bid leveling, deal-term negotiation brief, listing proposal, OM/teaser, and PSA-to-close coordination.","validation_gate":"Verify the specific skill file and source evidence before adopting detailed behavior or valuation logic.","human_review_boundary":"optional unless output affects a person or external system","safety_boundary":"keep as reference pattern until copied into an ECC contract","codex_package_relevance":"Useful as a CRE workflow catalog reference for brokerage transaction doors and artifact names.","what_to_copy":"Copy the transaction-stage taxonomy and artifact-oriented workflow names.","what_to_ignore":"Ignore unverified valuation, legal, negotiation, or marketing claims until the relevant skill and supporting evidence are inspected.","tags":"commercial real estate, brokerage, investment sales, BOV, data room, bid leveling, transaction coordination","confidence":"medium"},{"workflow_id":"surface-0044","workflow_name":"CRE Due Diligence plugin pack","source_repo":"ahacker-1/cre-agent-skills","source_url":"https://github.com/ahacker-1/cre-agent-skills/tree/main/plugins/cre-due-diligence","source_url_status":"canonicalized","canonical_source_url":"https://github.com/ahacker-1/cre-agent-skills/tree/main/claude-code-plugins/cre-due-diligence","evidence_basis":"README fallback","domain":"real_estate","workflow_type":"EvidenceAudit","real_life_job":"Route commercial real estate due-diligence requests across rent roll, operating expense, market, physical, environmental, title, and tenant-credit review workflows.","input_contract":"public records, source links, addresses, entity names, evidence files, rent rolls, T-12 operating expenses, market data, physical reports, environmental materials, title/survey materials, tenant credit data","output_artifact":"evidence packet, due-diligence brief, caveated report, rent roll analysis, OpEx benchmark, market study, physical/environmental/title review, tenant credit review","trigger":"Use when catalog lookup needs a packaged CRE due-diligence reference rather than a single skill file.","tools_or_sources":"Original plugins path was not the repo path shown in the README. README identifies the canonical plugin path as claude-code-plugins/cre-due-diligence and describes 7 included skills: rent roll, OpEx, market, physical, environmental, title, and tenant credit.","validation_gate":"Open the canonical plugin folder or SKILL entry point before copying routing behavior; README fallback supports package identity and included skill categories.","human_review_boundary":"required before final action or conclusion","safety_boundary":"must not make legal, medical, engineering, compliance, or safety conclusions without human review","codex_package_relevance":"Relevant as a package-level CRE due-diligence catalog door and routing pattern, but should be translated into an ECC contract before reuse.","what_to_copy":"Copy the package grouping and due-diligence lane list as catalog metadata.","what_to_ignore":"Ignore the broken original path and do not import plugin mechanics or unstated due-diligence conclusions without canonical file inspection.","tags":"commercial real estate, due diligence, plugin pack, rent roll, OpEx, market study, environmental, title, tenant credit","confidence":"medium"}]}
