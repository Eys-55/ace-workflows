{
  "name": "workflow-foundry-tracker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "astro build",
    "dev": "astro dev --host 127.0.0.1",
    "test": "npm run test:data",
    "test:data": "node --test tests/workflow-state.test.mjs tests/testing-session-state.test.mjs tests/workflow-state-validation-core.test.mjs tests/workflow-deliverable-contracts.test.mjs tests/workflow-deliverable-boundaries.test.mjs tests/workflow-skill-catalog.test.mjs tests/workflow-skill-routing.test.mjs tests/workflow-release-gates.test.mjs tests/workflow-product-skill.test.mjs tests/workflow-integration-readiness.test.mjs",
    "test:coverage": "npm run test:coverage:schema && npm run test:coverage:readiness && npm run test:coverage:catalog && npm run test:coverage:evidence",
    "test:coverage:schema": "node --test --experimental-test-coverage --test-coverage-include=../../../scripts/workflow-contract-schema.mjs --test-coverage-lines=80 --test-coverage-branches=80 --test-coverage-functions=80 tests/workflow-deliverable-contracts.test.mjs tests/workflow-deliverable-boundaries.test.mjs tests/workflow-skill-catalog.test.mjs tests/workflow-skill-routing.test.mjs",
    "test:coverage:readiness": "node --test --experimental-test-coverage --test-coverage-include=../../../scripts/workflow-contract-readiness.mjs --test-coverage-lines=80 --test-coverage-branches=80 --test-coverage-functions=80 tests/workflow-deliverable-contracts.test.mjs tests/workflow-deliverable-boundaries.test.mjs tests/workflow-skill-catalog.test.mjs tests/workflow-skill-routing.test.mjs tests/workflow-release-gates.test.mjs",
    "test:coverage:catalog": "node --test --experimental-test-coverage --test-coverage-include=../../../scripts/workflow-skill-catalog.mjs --test-coverage-lines=80 --test-coverage-branches=80 --test-coverage-functions=80 tests/workflow-deliverable-contracts.test.mjs tests/workflow-deliverable-boundaries.test.mjs tests/workflow-skill-catalog.test.mjs tests/workflow-skill-routing.test.mjs",
    "test:coverage:evidence": "node --test --experimental-test-coverage --test-coverage-include=../../../scripts/workflow-release-evidence-validation.mjs --test-coverage-lines=80 --test-coverage-branches=80 --test-coverage-functions=80 tests/workflow-release-gates.test.mjs",
    "test:output": "node --test tests/generated-output.test.mjs",
    "verify": "npm run test:data && npm run test:coverage && npm run build && npm run test:output"
  },
  "dependencies": {
    "astro": "^7.0.6"
  }
}
