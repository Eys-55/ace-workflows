---
import { loadWorkflowState } from "../lib/workflow-state.mjs";

const workflow = await loadWorkflowState();
const statusCounts = workflow.projects
  .flatMap((project) => project.tasks)
  .reduce((counts, task) => {
    counts[task.status] = (counts[task.status] ?? 0) + 1;
    return counts;
  }, {});

function taskCountLabel(count) {
  return count === 1 ? "1 task" : `${count} tasks`;
}
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="data:," />
    <title>Workflow Foundry Tracker</title>
    <style>
      :root {
        color-scheme: dark;
        --bg: #111318;
        --panel: #181b22;
        --panel-strong: #20242d;
        --panel-soft: #151820;
        --text: #f5f7fa;
        --muted: #a8b0bf;
        --line: #323945;
        --accent: #67e8f9;
        --green: #86efac;
        --yellow: #fde68a;
        --red: #fca5a5;
        --blue: #93c5fd;
        --violet: #c4b5fd;
      }

      [data-theme="light"] {
        color-scheme: light;
        --bg: #f6f7f9;
        --panel: #ffffff;
        --panel-strong: #edf1f5;
        --panel-soft: #f9fafb;
        --text: #171a21;
        --muted: #5f6876;
        --line: #d8dee8;
        --accent: #0369a1;
        --green: #15803d;
        --yellow: #92400e;
        --red: #b91c1c;
        --blue: #1d4ed8;
        --violet: #6d28d9;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-height: 100vh;
        background: var(--bg);
        color: var(--text);
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
          "Segoe UI", sans-serif;
        letter-spacing: 0;
      }

      button,
      input {
        font: inherit;
      }

      button {
        cursor: pointer;
      }

      .shell {
        width: min(1540px, 100%);
        margin: 0 auto;
        padding: 22px;
      }

      .topbar {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 18px;
        align-items: start;
        padding: 14px 0 18px;
      }

      h1 {
        margin: 0;
        font-size: 34px;
        line-height: 1.05;
        letter-spacing: 0;
      }

      .subtitle {
        max-width: 780px;
        margin: 8px 0 0;
        color: var(--muted);
        font-size: 15px;
        line-height: 1.45;
      }

      .controls {
        display: flex;
        flex-wrap: wrap;
        justify-content: flex-end;
        gap: 10px;
      }

      .control,
      .iconless-button,
      .status-chip {
        min-height: 38px;
        border: 1px solid var(--line);
        border-radius: 8px;
        background: var(--panel);
        color: var(--text);
        padding: 8px 11px;
      }

      .control[aria-pressed="true"],
      .status-chip[aria-pressed="true"],
      .status-chip.current-status {
        border-color: var(--accent);
        background: var(--panel-strong);
      }

      .summary {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 10px;
        margin: 0 0 16px;
      }

      .metric,
      .project-sidebar,
      .workspace {
        border: 1px solid var(--line);
        border-radius: 8px;
        background: var(--panel);
      }

      .metric {
        padding: 12px;
      }

      .metric span,
      .eyebrow {
        display: block;
        color: var(--muted);
        font-size: 12px;
        text-transform: uppercase;
      }

      .metric strong {
        display: block;
        margin-top: 5px;
        font-size: 22px;
      }

      .app-grid {
        display: grid;
        grid-template-columns: minmax(230px, 300px) minmax(0, 1fr);
        gap: 14px;
        align-items: start;
      }

      .project-sidebar {
        position: sticky;
        top: 16px;
        padding: 12px;
      }

      .field {
        width: 100%;
        min-height: 38px;
        border: 1px solid var(--line);
        border-radius: 8px;
        background: var(--panel-soft);
        color: var(--text);
        padding: 8px 10px;
      }

      .field::placeholder {
        color: var(--muted);
      }

      .project-list {
        display: grid;
        gap: 8px;
        margin-top: 10px;
      }

      .project-button {
        width: 100%;
        border: 1px solid var(--line);
        border-radius: 8px;
        background: var(--panel-soft);
        color: var(--text);
        padding: 10px;
        text-align: left;
      }

      .project-button[aria-current="true"] {
        border-color: var(--accent);
        background: var(--panel-strong);
      }

      .project-name,
      .task-title {
        display: block;
        font-weight: 700;
        line-height: 1.25;
      }

      .project-slug,
      .task-id,
      .muted,
      .artifact-path {
        color: var(--muted);
      }

      .project-button-meta,
      .task-meta,
      .artifact-summary {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        margin-top: 8px;
      }

      .mini-pill,
      .artifact-pill,
      .status-pill {
        display: inline-flex;
        align-items: center;
        max-width: 100%;
        min-height: 22px;
        border: 1px solid var(--line);
        border-radius: 999px;
        padding: 3px 8px;
        background: var(--panel-strong);
        color: var(--muted);
        font-size: 12px;
        white-space: nowrap;
      }

      .workspace {
        min-width: 0;
        padding: 14px;
      }

      .project-pane[hidden],
      .task-detail[hidden],
      .task-row[hidden],
      .project-button[hidden],
      .task-section[hidden] {
        display: none;
      }

      .project-heading {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 12px;
        align-items: start;
        margin-bottom: 12px;
      }

      .project-heading h2 {
        margin: 0;
        font-size: 24px;
        line-height: 1.15;
      }

      .project-context {
        margin-top: 6px;
        color: var(--muted);
        font-size: 13px;
        line-height: 1.4;
      }

      .project-stats {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 8px;
        margin: 12px 0;
      }

      .stat-box {
        border: 1px solid var(--line);
        border-radius: 8px;
        background: var(--panel-soft);
        padding: 10px;
      }

      .stat-box span {
        display: block;
        color: var(--muted);
        font-size: 11px;
        text-transform: uppercase;
      }

      .stat-box strong {
        display: block;
        margin-top: 4px;
        font-size: 20px;
      }

      .rail {
        border: 1px solid var(--line);
        border-radius: 8px;
        background: var(--panel-soft);
        padding: 10px;
        margin: 12px 0;
      }

      .rail-label {
        margin-bottom: 8px;
      }

      .status-list {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
      }

      .status-chip {
        min-height: 32px;
        font-size: 12px;
      }

      .task-toolbar {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 10px;
        align-items: center;
        margin: 12px 0;
      }

      .task-layout {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(300px, 380px);
        gap: 12px;
        align-items: start;
      }

      .task-list,
      .detail-stack {
        min-width: 0;
      }

      .task-section {
        display: grid;
        gap: 8px;
      }

      .task-section + .task-section,
      .done-group {
        margin-top: 12px;
      }

      .section-title {
        margin: 0;
        color: var(--muted);
        font-size: 12px;
        text-transform: uppercase;
      }

      .task-row {
        border: 1px solid var(--line);
        border-radius: 8px;
        background: var(--panel-soft);
        padding: 0;
      }

      .task-row[aria-selected="true"] {
        border-color: var(--accent);
        background: var(--panel-strong);
      }

      .task-button {
        width: 100%;
        border: 0;
        background: transparent;
        color: inherit;
        padding: 12px;
        text-align: left;
      }

      .task-row-header {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 10px;
        align-items: start;
      }

      .task-title,
      .task-id,
      .next-action {
        overflow: hidden;
        text-overflow: ellipsis;
      }

      .task-title,
      .next-action {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
      }

      .task-id {
        display: block;
        margin-top: 4px;
        white-space: nowrap;
      }

      .next-action {
        margin-top: 9px;
        color: var(--muted);
        font-size: 13px;
        line-height: 1.35;
      }

      .status-in-progress,
      .status-in-progress {
        color: var(--blue);
      }

      .status-done {
        color: var(--green);
      }

      .status-blocked {
        color: var(--red);
      }

      .status-todo {
        color: var(--yellow);
      }

      .status-todo {
        color: var(--violet);
      }

      .task-detail {
        border: 1px solid var(--line);
        border-radius: 8px;
        background: var(--panel-soft);
        padding: 14px;
      }

      .task-detail h3 {
        margin: 0;
        font-size: 20px;
        line-height: 1.2;
      }

      .detail-block {
        border-top: 1px solid var(--line);
        margin-top: 12px;
        padding-top: 12px;
      }

      .detail-block h4 {
        margin: 0 0 8px;
        font-size: 13px;
        text-transform: uppercase;
      }

      .command-box {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 8px;
        align-items: center;
        border: 1px solid var(--line);
        border-radius: 8px;
        background: var(--panel);
        padding: 8px;
      }

      code {
        overflow-wrap: anywhere;
        color: var(--accent);
        font-family:
          "SFMono-Regular", Consolas, "Liberation Mono", monospace;
        font-size: 12px;
      }

      .artifact-group {
        display: grid;
        gap: 6px;
        margin-top: 8px;
      }

      details {
        border: 1px solid var(--line);
        border-radius: 8px;
        background: var(--panel);
        padding: 8px;
      }

      details + details {
        margin-top: 8px;
      }

      summary {
        cursor: pointer;
        color: var(--text);
      }

      .path-list,
      .session-list {
        display: grid;
        gap: 7px;
        margin: 8px 0 0;
        padding-left: 18px;
      }

      .artifact-path {
        overflow-wrap: anywhere;
        font-size: 12px;
      }

      .snapshot {
        margin-top: 16px;
        color: var(--muted);
        font-size: 12px;
        line-height: 1.4;
      }

      @media (max-width: 1080px) {
        .app-grid,
        .task-layout {
          grid-template-columns: 1fr;
        }

        .project-sidebar {
          position: static;
        }

        .task-detail {
          margin-top: 8px;
        }
      }

      @media (max-width: 760px) {
        .shell {
          padding: 14px;
        }

        .topbar,
        .project-heading,
        .task-toolbar,
        .task-row-header {
          grid-template-columns: 1fr;
        }

        .controls {
          justify-content: flex-start;
        }

        .summary,
        .project-stats {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }
      }

      @media (max-width: 480px) {
        h1 {
          font-size: 28px;
        }

        .summary,
        .project-stats {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>
  <body>
    <main class="shell">
      <header class="topbar">
        <div>
          <h1>Workflow Foundry Tracker</h1>
          <p class="subtitle">
            Read-only generated snapshot from project and task JSON. Rebuild the
            tracker after JSON changes to refresh this view.
          </p>
        </div>
        <div class="controls" aria-label="Tracker view controls">
          <button class="control" type="button" id="theme-toggle" aria-pressed="true">
            Dark mode
          </button>
        </div>
      </header>

      <section class="summary" aria-label="Workflow summary">
        <div class="metric">
          <span>Projects</span>
          <strong>{workflow.projectCount}</strong>
        </div>
        <div class="metric">
          <span>Tasks</span>
          <strong>{workflow.taskCount}</strong>
        </div>
        <div class="metric">
          <span>Active skills</span>
          <strong>{workflow.skillCatalog.skills.length}</strong>
        </div>
        <div class="metric">
          <span>In progress</span>
          <strong>{statusCounts["in-progress"] ?? 0}</strong>
        </div>
        <div class="metric">
          <span>Blocked</span>
          <strong>{statusCounts.blocked ?? 0}</strong>
        </div>
      </section>

      <section class="project-header" aria-label="Canonical skill discovery">
        <div>
          <span class="eyebrow">Derived skill catalog</span>
          <h2>Runtime discovery</h2>
          <p class="muted">Read-only from complete `.agents/skills/*` bundles.</p>
        </div>
        <div class="artifact-group">
          <details>
            <summary>Active skills · {workflow.skillCatalog.skills.length}</summary>
            <ul class="path-list">
              {workflow.skillCatalog.skills.map((skill) => (
                <li>
                  <strong>{skill.invocation}</strong>
                  <div class="artifact-path">{skill.runtimeVisibility} · {skill.runtimeTargets.join(", ")}</div>
                  <div class="artifact-path">{skill.skillPath}</div>
                </li>
              ))}
            </ul>
          </details>
          {workflow.skillCatalog.errors.length > 0 && (
            <details open>
              <summary>Discovery blockers · {workflow.skillCatalog.errors.length}</summary>
              <ul class="session-list">
                {workflow.skillCatalog.errors.map((error) => (
                  <li><strong>{error.code}</strong> · {error.path} · {error.message}</li>
                ))}
              </ul>
            </details>
          )}
        </div>
      </section>

      <div class="app-grid">
        <aside class="project-sidebar" aria-label="Projects">
          <label class="eyebrow" for="project-search">Search projects</label>
          <input
            class="field"
            id="project-search"
            type="search"
            placeholder="Search projects"
            autocomplete="off"
          />
          <div class="project-list">
            {
              workflow.projects.map((project) => (
                <button
                  class="project-button"
                  type="button"
                  data-project-button
                  data-project-target={project.slug}
                  data-project-search={`${project.name} ${project.slug}`.toLowerCase()}
                  aria-current={String(project.slug === workflow.currentProjectSlug)}
                >
                  <span class="project-name">{project.name}</span>
                  <span class="project-slug">{project.slug}</span>
                  <span class="project-button-meta">
                    <span class="mini-pill">{taskCountLabel(project.activeTaskCount)} active</span>
                    <span class="mini-pill">{project.stats.blocked} blocked</span>
                    <span class={`mini-pill status-${project.attentionStatus}`}>
                      {project.attentionStatus}
                    </span>
                  </span>
                </button>
              ))
            }
          </div>
        </aside>

        <section class="workspace" aria-label="Selected project workflow">
          {
            workflow.projects.map((project) => {
              const activeTasks = project.tasks.filter((task) => task.status !== "done");
              const doneTasks = project.tasks.filter((task) => task.status === "done");
              const defaultTask =
                activeTasks.find((task) => task.status === project.attentionStatus) ??
                activeTasks.find((task) => task.status === "in-progress") ??
                activeTasks[0] ??
                project.tasks[0];

              return (
                <section
                  class="project-pane"
                  data-project-panel
                  data-project={project.slug}
                  hidden={project.slug !== workflow.currentProjectSlug}
                >
                  <header class="project-heading">
                    <div>
                      <span class="eyebrow">Selected project</span>
                      <h2>{project.name}</h2>
                      <div class="project-context">
                        {project.slug} · {project.state} · {project.domain}
                      </div>
                      <div class="project-context">{project.goal}</div>
                    </div>
                    <span class="mini-pill">updated {project.updatedAt}</span>
                  </header>

                  <section class="project-stats" aria-label={`${project.name} summary`}>
                    <div class="stat-box">
                      <span>Open</span>
                      <strong>{project.stats.open}</strong>
                    </div>
                    <div class="stat-box">
                      <span>Blocked</span>
                      <strong>{project.stats.blocked}</strong>
                    </div>
                    <div class="stat-box">
                      <span>In progress</span>
                      <strong>{project.stats.inProgress}</strong>
                    </div>
                    <div class="stat-box">
                      <span>Done</span>
                      <strong>{project.stats.done}</strong>
                    </div>
                  </section>

                  <section class="rail" aria-label="Status overview">
                    <div class="eyebrow rail-label">Status overview</div>
                    <div class="status-list">
                      <button
                        class="status-chip"
                        type="button"
                        data-status-filter="all"
                        aria-pressed="true"
                      >
                        All
                      </button>
                      {workflow.statusStages.map((stage) => (
                        <button
                          class={`status-chip status-${stage.id}`}
                          type="button"
                          data-status-filter={stage.id}
                          aria-pressed="false"
                        >
                          {stage.label}
                        </button>
                      ))}
                    </div>
                  </section>

                  <div class="task-toolbar">
                    <label class="eyebrow" for={`task-search-${project.slug}`}>
                      Search selected project tasks
                    </label>
                    <input
                      class="field"
                      id={`task-search-${project.slug}`}
                      type="search"
                      placeholder="Search selected project tasks"
                      autocomplete="off"
                      data-task-search
                    />
                  </div>

                  <div class="task-layout">
                    <div class="task-list">
                      <section class="task-section" data-task-section>
                        <h3 class="section-title">Active workflows</h3>
                        {activeTasks.map((task) => (
                          <article
                            class="task-row"
                            data-task-row
                            data-task-id={task.id}
                            data-status={task.status}
                            data-search={task.searchText}
                            aria-selected={String(task.id === defaultTask?.id)}
                          >
                            <button class="task-button" type="button" data-task-button>
                              <span class="task-row-header">
                                <span>
                                  <span class="task-title">{task.title}</span>
                                  <span class="task-id">{task.id}</span>
                                </span>
                                <span class={`status-pill status-${task.status}`}>
                                  {task.status}
                                </span>
                              </span>
                              <span class="task-meta">
                                <span class="mini-pill">{task.kind}</span>
                                <span class={`mini-pill status-${task.status}`}>{task.status}</span>
                              </span>
                              <span class="next-action">Next: {task.nextAction}</span>
                              <span class="artifact-summary">
                                {task.artifactGroupList
                                  .filter((group) => group.count > 0)
                                  .map((group) => (
                                    <span class="artifact-pill">
                                      {group.label} {group.count}
                                    </span>
                                  ))}
                              </span>
                            </button>
                          </article>
                        ))}
                      </section>

                      {doneTasks.length > 0 && (
                        <details class="done-group">
                          <summary>Done · {doneTasks.length}</summary>
                          <section class="task-section" data-task-section>
                            {doneTasks.map((task) => (
                              <article
                                class="task-row"
                                data-task-row
                                data-task-id={task.id}
                                data-status={task.status}
                                data-search={task.searchText}
                                aria-selected={String(task.id === defaultTask?.id)}
                              >
                                <button class="task-button" type="button" data-task-button>
                                  <span class="task-row-header">
                                    <span>
                                      <span class="task-title">{task.title}</span>
                                      <span class="task-id">{task.id}</span>
                                    </span>
                                    <span class={`status-pill status-${task.status}`}>
                                      {task.status}
                                    </span>
                                  </span>
                                  <span class="next-action">Next: {task.nextAction}</span>
                                </button>
                              </article>
                            ))}
                          </section>
                        </details>
                      )}
                    </div>

                    <aside class="detail-stack" aria-label={`${project.name} task detail`}>
                      {project.tasks.map((task) => (
                        <section
                          class="task-detail"
                          data-task-detail
                          data-task-id={task.id}
                          hidden={task.id !== defaultTask?.id}
                        >
                          <span class="eyebrow">Task detail</span>
                          <h3>{task.title}</h3>
                          <div class="project-context">{task.id}</div>
                          <div class="task-meta">
                            <span class={`mini-pill status-${task.status}`}>{task.status}</span>
                            <span class="mini-pill">{task.kind}</span>
                          </div>

                          <section class="detail-block">
                            <h4>Next Action</h4>
                            <p class="muted">Next: {task.nextAction}</p>
                            <p class="muted">
                              Project JSON loaded, task JSON loaded, linked artifacts counted,
                              and the ledger remains read-only.
                            </p>
                          </section>

                          <section class="detail-block">
                            <h4>Deliverable Readiness</h4>
                            <p class="muted">
                              State: {task.deliverableReadiness.state}; completion: {task.deliverableReadiness.completion_ready ? "ready" : "blocked"}.
                            </p>
                            {task.deliverableContracts.length > 0 ? (
                              <ul class="path-list">
                                {task.deliverableContracts.map((contract) => (
                                  <li>
                                    <strong>{contract.deliverableId}</strong>
                                    <div class="artifact-path">
                                      {contract.kind} · {contract.role} · {contract.runtimeVisibility}
                                    </div>
                                    <div class="artifact-path">{contract.targetSurface}</div>
                                  </li>
                                ))}
                              </ul>
                            ) : (
                              <p class="muted">No native contract; historical compatibility or migration is pending.</p>
                            )}
                            {task.deliverableReadiness.blockers.length > 0 && (
                              <ul class="session-list">
                                {task.deliverableReadiness.blockers.map((blocker) => (
                                  <li>
                                    <strong>{blocker.code}</strong> · {blocker.message}
                                  </li>
                                ))}
                              </ul>
                            )}
                            {task.deliverableReadiness.deliverables
                              .filter((deliverable) => deliverable.discovery.required)
                              .map((deliverable) => (
                                <p class="muted">
                                  Discovery {deliverable.deliverable_id}: {deliverable.discovery.ready ? "ready" : "blocked"}
                                  {deliverable.discovery.catalog_entry
                                    ? ` · ${deliverable.discovery.catalog_entry.invocation}`
                                    : ""}
                                </p>
                              ))}
                            <p class="muted">Read-only projection from task JSON and the derived skill catalog.</p>
                          </section>

                          <section class="detail-block">
                            <h4>Linked Artifacts</h4>
                            <div class="artifact-group">
                              {task.artifactGroupList
                                .filter((group) => group.count > 0)
                                .map((group) => (
                                  <details>
                                    <summary>
                                      {group.label} · {group.count}
                                    </summary>
                                    <ul class="path-list">
                                      {group.items.map((artifact) => (
                                        <li>
                                          <strong>{artifact.label}</strong>
                                          <div class="artifact-path">{artifact.path}</div>
                                        </li>
                                      ))}
                                    </ul>
                                  </details>
                                ))}
                            </div>
                          </section>

                          <section class="detail-block">
                            <h4>Session Log</h4>
                            {task.recentSessionEvents.length > 0 ? (
                              <ul class="session-list">
                                {task.recentSessionEvents.map((entry) => (
                                  <li>
                                    <span class="muted">{entry.date}</span> · {entry.event}
                                  </li>
                                ))}
                              </ul>
                            ) : (
                              <p class="muted">No session events recorded.</p>
                            )}
                            {task.sessionLog.length > task.recentSessionEvents.length && (
                              <details>
                                <summary>Full log · {task.sessionLog.length}</summary>
                                <ul class="session-list">
                                  {task.sessionLog.map((entry) => (
                                    <li>
                                      <span class="muted">{entry.date}</span> · {entry.event}
                                    </li>
                                  ))}
                                </ul>
                              </details>
                            )}
                          </section>
                        </section>
                      ))}
                    </aside>
                  </div>
                </section>
              );
            })
          }
        </section>
      </div>

      <footer class="snapshot">
        Generated {workflow.generatedAt}. Source: projects/*/project.json and
        projects/*/tasks/*.json. Current project: {workflow.currentProjectSlug}.
      </footer>
    </main>

    <script>
      const root = document.documentElement;
      const themeToggle = document.querySelector("#theme-toggle");
      const projectSearch = document.querySelector("#project-search");
      const projectButtons = Array.from(document.querySelectorAll("[data-project-button]"));
      const projectPanels = Array.from(document.querySelectorAll("[data-project-panel]"));
      const storage = {
        project: "workflow-foundry-tracker-project",
        task: "workflow-foundry-tracker-task",
      };

      function readStored(key) {
        try {
          return window.localStorage.getItem(key);
        } catch {
          return null;
        }
      }

      function writeStored(key, value) {
        try {
          window.localStorage.setItem(key, value);
        } catch {
          // localStorage is optional browser UI state only.
        }
      }

      function activePanel() {
        return projectPanels.find((panel) => !panel.hidden);
      }

      function selectProject(slug) {
        projectButtons.forEach((button) => {
          const isActive = button.dataset.projectTarget === slug;
          button.setAttribute("aria-current", String(isActive));
        });

        projectPanels.forEach((panel) => {
          panel.hidden = panel.dataset.project !== slug;
        });

        const panel = activePanel();
        if (!panel) return;

        writeStored(storage.project, slug);
        const storedTask = readStored(`${storage.task}:${slug}`);
        const task =
          (storedTask && panel.querySelector(`[data-task-row][data-task-id="${storedTask}"]`)) ||
          panel.querySelector('[data-task-row][aria-selected="true"]') ||
          panel.querySelector("[data-task-row]");

        if (task instanceof HTMLElement) {
          selectTask(task.dataset.taskId);
        }

        applyTaskFilters(panel);
      }

      function selectTask(taskId) {
        if (!taskId) return;
        const panel = activePanel();
        if (!panel) return;

        panel.querySelectorAll("[data-task-row]").forEach((row) => {
          row.setAttribute("aria-selected", String(row.dataset.taskId === taskId));
        });

        panel.querySelectorAll("[data-task-detail]").forEach((detail) => {
          detail.hidden = detail.dataset.taskId !== taskId;
        });

        const selectedRow = panel.querySelector(`[data-task-row][data-task-id="${taskId}"]`);
        const selectedStatus = selectedRow instanceof HTMLElement ? selectedRow.dataset.status : "";

        panel.querySelectorAll("[data-status-filter]").forEach((button) => {
          button.classList.toggle("current-status", button.dataset.statusFilter === selectedStatus);
        });

        writeStored(`${storage.task}:${panel.dataset.project}`, taskId);
      }

      function applyTaskFilters(panel) {
        const query = panel.querySelector("[data-task-search]")?.value.trim().toLowerCase() ?? "";
        const activeStatus =
          panel.querySelector('[data-status-filter][aria-pressed="true"]')?.dataset.statusFilter ??
          "all";

        panel.querySelectorAll("[data-task-row]").forEach((row) => {
          const matchesQuery = row.dataset.search?.includes(query) ?? true;
          const matchesStatus = activeStatus === "all" || row.dataset.status === activeStatus;
          row.hidden = !matchesQuery || !matchesStatus;
        });

        panel.querySelectorAll("[data-task-section]").forEach((section) => {
          const visibleRows = Array.from(section.querySelectorAll("[data-task-row]")).some(
            (row) => !row.hidden,
          );
          section.hidden = !visibleRows;
        });
      }

      themeToggle?.addEventListener("click", () => {
        const nextTheme = root.dataset.theme === "dark" ? "light" : "dark";
        root.dataset.theme = nextTheme;
        themeToggle.textContent = nextTheme === "dark" ? "Dark mode" : "Light mode";
        themeToggle.setAttribute("aria-pressed", String(nextTheme === "dark"));
      });

      projectSearch?.addEventListener("input", () => {
        const query = projectSearch.value.trim().toLowerCase();
        projectButtons.forEach((button) => {
          button.hidden = !(button.dataset.projectSearch ?? "").includes(query);
        });
      });

      projectButtons.forEach((button) => {
        button.addEventListener("click", () => {
          selectProject(button.dataset.projectTarget);
        });
      });

      projectPanels.forEach((panel) => {
        panel.querySelector("[data-task-search]")?.addEventListener("input", () => {
          applyTaskFilters(panel);
        });

        panel.querySelectorAll("[data-status-filter]").forEach((button) => {
          button.addEventListener("click", () => {
            panel.querySelectorAll("[data-status-filter]").forEach((statusButton) => {
              statusButton.setAttribute("aria-pressed", String(statusButton === button));
            });
            applyTaskFilters(panel);
          });
        });

        panel.querySelectorAll("[data-task-button]").forEach((button) => {
          button.addEventListener("click", () => {
            const row = button.closest("[data-task-row]");
            if (row instanceof HTMLElement) selectTask(row.dataset.taskId);
          });
        });

      });

      const initialProject =
        readStored(storage.project) ??
        document.querySelector("[data-project-panel]:not([hidden])")?.dataset.project;
      if (initialProject) selectProject(initialProject);
    </script>
  </body>
</html>
